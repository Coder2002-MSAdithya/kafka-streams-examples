digraph ra {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", splines=ortho, nodesep=0.35, ranksep=0.5, ordering="out"];
  node [fontname="Helvetica", fontsize=11, style=filled, height=0.3, margin="0.08,0.04"];
  edge [fontname="Helvetica", color="#444444", arrowsize=0.65];
  label="StockService (stock-svc)\nRelational algebra (tree)";
  labelloc=t;
  fontsize=14;
  subgraph cluster_0 {
    label="ORDER_EVENT_TOPIC → STOCK_CHECK_EVENT_TOPIC"; style=rounded; color="#adb5bd"; fontsize=10;
    r0t0 [label="Sink(STOCK_CHECK_EVENT_TOPIC)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t1 [label=<<<B>π</B><BR ALIGN='LEFT'/>customerId, productId, amount, inStock, cardNumber>>, shape=box, style="rounded,filled", fillcolor="#e8f4fc"];
    r0t2 [label="Scan(ORDER_EVENT_TOPIC)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t2 -> r0t1;
    r0t1 -> r0t0;
    r0anchor [style=invis, width=0, height=0, label=""];
    r0t0 -> r0anchor [style=invis];
    r0anchor -> r0note [style=invis];
    r0note [label="out: customerId, productId, amount, inStock, cardNumber\ndropped: price", shape=note, fillcolor="#f8f9fa", fontsize=10];
    { rank=max; r0note; }
  }
}