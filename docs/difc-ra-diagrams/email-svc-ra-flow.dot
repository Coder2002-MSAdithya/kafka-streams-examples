digraph ra {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", splines=ortho, nodesep=0.35, ranksep=0.5, ordering="out"];
  node [fontname="Helvetica", fontsize=11, style=filled, height=0.3, margin="0.08,0.04"];
  edge [fontname="Helvetica", color="#444444", arrowsize=0.65];
  label="EmailService (email-svc)\nRelational algebra (tree)";
  labelloc=t;
  fontsize=14;
  subgraph cluster_0 {
    label="orders, payments, customers → orders-enriched"; style=rounded; color="#adb5bd"; fontsize=10;
    r0t0 [label="Sink(orders-enriched)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t1 [label="⋈\nπ: product, id, state, customerId, quantity, +5", shape=hexagon, style="filled", fillcolor="#fff3cd"];
    r0t2 [label="stream\nπ: product, id, state, customerId, quantity, +1", shape=box, style="rounded,filled", fillcolor="#e8f4fc"];
    r0t3 [label="Scan(orders)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t3 -> r0t2;
    r0t2 -> r0t1;
    r0t4 [label="Scan(payments)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t4 -> r0t1;
    r0t5 [label="Scan(customers)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t5 -> r0t1;
    r0t1 -> r0t0;
    r0anchor [style=invis, width=0, height=0, label=""];
    r0t0 -> r0anchor [style=invis];
    r0anchor -> r0note [style=invis];
    r0note [label="out: product, id, state, customerId, quantity, +5\nin: product, id, state, customerId, quantity, +5", shape=note, fillcolor="#f8f9fa", fontsize=10];
    { rank=max; r0note; }
  }
}