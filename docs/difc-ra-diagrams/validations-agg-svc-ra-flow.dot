digraph ra {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", splines=ortho, nodesep=0.35, ranksep=0.5, ordering="out"];
  node [fontname="Helvetica", fontsize=11, style=filled, height=0.3, margin="0.08,0.04"];
  edge [fontname="Helvetica", color="#444444", arrowsize=0.65];
  label="ValidationsAggregatorService (validations-agg-svc)\nRelational algebra (tree)";
  labelloc=t;
  fontsize=14;
  subgraph cluster_0 {
    label="order-validations, orders → orders"; style=rounded; color="#adb5bd"; fontsize=10;
    r0t0 [label="Sink(orders)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t1 [label="∪\nπ: _aggregate_value, quantity, price, product, id, +2", shape=diamond, style="filled", fillcolor="#ffe8cc"];
    r0t2 [label="π_k\nπ: _aggregate_value, quantity, price, product, id, +2", shape=box, style="rounded,filled", fillcolor="#e8f4fc"];
    r0t3 [label="γ\nπ: _aggregate_value, quantity, price, product, id, +2", shape=box, style="rounded,filled", fillcolor="#fff3cd"];
    r0t4 [label="⋈\nπ: _aggregate_value, quantity, price, product, id, +2", shape=hexagon, style="filled", fillcolor="#fff3cd"];
    r0t5 [label="γ\nπ: _aggregate_value", shape=box, style="rounded,filled", fillcolor="#fff3cd"];
    r0t6 [label="σ\nπ: orderId, validationResult, checkType", shape=box, style="rounded,filled", fillcolor="#e8f4fc"];
    r0t7 [label="γ\nπ: orderId, validationResult, checkType", shape=box, style="rounded,filled", fillcolor="#fff3cd"];
    r0t8 [label="Scan(order-validations)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t8 -> r0t7;
    r0t7 -> r0t6;
    r0t6 -> r0t5;
    r0t5 -> r0t4;
    r0t9 [label="Scan(orders)", shape=ellipse, style="filled", fillcolor="#d4edda"];
    r0t9 -> r0t4;
    { rank=same; r0t5; r0t9; }
    r0t4 -> r0t3;
    r0t3 -> r0t2;
    r0t2 -> r0t1;
    r0t1 -> r0t0;
    r0anchor [style=invis, width=0, height=0, label=""];
    r0t0 -> r0anchor [style=invis];
    r0anchor -> r0note [style=invis];
    r0note [label="out: _aggregate_value, quantity, price, product, id, +2\nin: orderId, validationResult, checkType, quantity, price, +4", shape=note, fillcolor="#f8f9fa", fontsize=10];
    { rank=max; r0note; }
  }
}