digraph policy {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", splines=polyline, nodesep=0.45, ranksep=0.55];
  node [fontname="Helvetica", fontsize=11, style=filled, height=0.35];
  edge [fontname="Helvetica", fontsize=9, color="#444444", arrowsize=0.7];
  label="OrderDetailsService (order-details-svc)\nProcessing policy graph (agent topology)";
  labelloc=t;
  fontsize=14;
  n_stream_1 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_topic_orders [label="orders", shape=ellipse, fillcolor="#d4edda"];
  n_stream_2 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_stream_3 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_op_4 [label="filter\nσ: id", shape=box, fillcolor="#cce5ff"];
  n_stream_5 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_op_6 [label="mapValues\nπ: checkType, orderId, validationResult", shape=box, fillcolor="#cce5ff"];
  n_stream_7 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_op_8 [label="declassifyTags", shape=box, fillcolor="#cce5ff"];
  n_stream_9 [label="KStream", shape=ellipse, fillcolor="#fdebd0"];
  n_op_10 [label="addTags", shape=box, fillcolor="#cce5ff"];
  n_op_11 [label="to", shape=box, fillcolor="#cce5ff"];
  n_topic_order_validations [label="order-validations", shape=ellipse, fillcolor="#d4edda"];
  n_comp_OrderDetailsService [label="OrderDetailsService (REST/producer)", shape=box, fillcolor="#f0f0f0"];
  n_comp_OrderDetailsService_op_0 [label="filter()\nσ: id", shape=box, fillcolor="#cce5ff"];
  n_comp_OrderDetailsService_op_1 [label="mapValues()\nπ: checkType, orderId, validationResult", shape=box, fillcolor="#cce5ff"];
  n_topic_orders -> n_stream_1 [label="source"];
  n_stream_2 -> n_op_4 [label="input"];
  n_op_4 -> n_stream_3 [label="output"];
  n_stream_3 -> n_op_6 [label="input"];
  n_op_6 -> n_stream_5 [label="output"];
  n_stream_5 -> n_op_8 [label="input"];
  n_op_8 -> n_stream_7 [label="output"];
  n_stream_7 -> n_op_10 [label="input"];
  n_op_10 -> n_stream_9 [label="output"];
  n_stream_9 -> n_op_11 [label="input"];
  n_op_11 -> n_topic_order_validations [label="writes"];
  n_topic_orders -> n_comp_OrderDetailsService [label="ingress"];
  n_topic_orders -> n_comp_OrderDetailsService_op_0 [label="source"];
  n_comp_OrderDetailsService_op_0 -> n_comp_OrderDetailsService_op_1 [label="input"];
  n_comp_OrderDetailsService_op_1 -> n_topic_order_validations [label="writes"];
}